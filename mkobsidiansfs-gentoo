#!/bin/bash
# mkobsidiansfs-gentoo - ObsidianOS Gentoo System Image Build Tool
set -e

# Function to check if a command exists
check_command() {
	local cmd="$1"
	local extra_msg="$2"
	if ! command -v "$cmd" &>/dev/null; then
		echo "Error: Required command '$cmd' not found. Please install it."
		[[ -n "$extra_msg" ]] && echo "$extra_msg"
		exit 1
	fi
}

if [[ $EUID -ne 0 ]]; then
	echo "This script must be run as root."
	exit 1
fi

# Check if git is installed (needed for dotfiles)
check_command git

# Default Settings. Do not edit, source a script that just edits these files.
BUILD_DIR="/tmp/obsidian_rootfs_gentoo" # SquashFS generation directory
GENTOO_ARCH="amd64"
GENTOO_INIT="systemd"        # or openrc, musl-openrc, hardened-openrc, musl-hardened-openrc, hardened-selinux-openrc, musl-systemd, hardened-systemd, musl-hardened-systemd, hardened-selinux-systemd 
GENTOO_PREFER_BINHOST="true" # set to anything other than `true` to disable
ACCEPT_LICENSE="*"
ENABLE_AMDGPU="true"         # enable AMD GPU Drivers
ENABLE_NVIDIA=""             # enable NVIDIA GPU Drivers
GENTOO_STAGE3_URL="-"        # URL to rootfs of stage3 of gentoo. `-` to dynamically fetch it
GENTOO_MIRROR="https://distfiles.gentoo.org/"
PACKAGES="dev-vcs/git sys-apps/baselayout sys-fs/dosfstools app-arch/p7zip app-arch/xz-utils sys-fs/mtools net-misc/networkmanager app-admin/sudo app-editors/nano app-editors/vim sys-boot/efibootmgr dev-lang/python sys-fs/squashfs-tools sys-apps/gptfdisk sys-fs/f2fs-tools sys-kernel/gentoo-kernel-bin sys-kernel/linux-firmware sys-kernel/dracut sys-boot/grub app-crypt/sbctl"
OUTPUT_SFS="system.sfs"    # Output SquashFS
TIMEZONE=""                # Olson Timezone
HOSTNAME="obsidian-gentoo" # Hostname
SERVICES="NetworkManager"  # Services to enable with systemctl (add plugind after obsidianctl install)
ROOT_HAVEPASSWORD=""       # Set this to anything other than blank to remove the password from the root user.
CUSTOM_SCRIPTS_DIR=""      # Place where scripts that must run in the SquashFS will run.
ADMIN_USER="user"          # Creates an user with the 'wheel' group
ADMIN_DOTFILES=""          # If an admin is created, a git repo that will be cloned to the new user.
ADMIN_PASSWORD=""          # Password to set for ADMIN_USER, if empty will ask interactively
ADMIN_DOTFILES_TYPE=""     # Type of dotfile repo. Requires git in PACKAGES if HOME or CONFIG.
# HOME - the inside of the repo has data for your home directory (ex: .zshrc, .config, .bashrc)
# CONFIG - the inside of the repo has data for your .config directory (ex: gtk, fish, kitty, hypr)
# * - ignore dotfiles repo (can be empty string) and copy dotfiles from that user's home.
#     recommended: set this to $SUDO_USER if this is being run with sudo.
POST_INSTALL="" # Line of bash to execute after installation is done

# Import settings from file. File extention: something.mkgentoosfs
if [[ "$1" != "" ]]; then
	source "$1"
	echo ">>> Custom config file specified: $1"
fi
if [[ -n "$oosnopass" ]]; then
	ROOT_HAVEPASSWORD="yesssssss"
	echo ">>> No password enabled via env var."
fi

# Validate GENTOO_INIT against the supported flavors before parsing.
case "$GENTOO_INIT" in
	systemd|openrc|\
	musl-systemd|musl-openrc|\
	hardened-systemd|hardened-openrc|\
	musl-hardened-systemd|musl-hardened-openrc|\
	hardened-selinux-systemd|hardened-selinux-openrc)
		;;
	*)
		echo "Error: Unknown GENTOO_INIT value '$GENTOO_INIT'." >&2
		echo "Supported: systemd, openrc, musl-{systemd,openrc}," >&2
		echo "  hardened-{systemd,openrc}, musl-hardened-{systemd,openrc}," >&2
		echo "  hardened-selinux-{systemd,openrc}" >&2
		exit 1 ;;
esac

# Parse GENTOO_INIT to extract the core init system, libc, and flavor
if [[ "$GENTOO_INIT" == musl-hardened-* ]]; then
    LIBC="musl"
    FLAVOR="musl/hardened"
    INIT_SYSTEM="${GENTOO_INIT#musl-hardened-}"
    SUB_PATH="$GENTOO_INIT"
elif [[ "$GENTOO_INIT" == musl-* ]]; then
    LIBC="musl"
    FLAVOR="musl"
    INIT_SYSTEM="${GENTOO_INIT#musl-}"
    SUB_PATH="$GENTOO_INIT"
elif [[ "$GENTOO_INIT" == hardened-selinux-* ]]; then
    LIBC="glibc"
    FLAVOR="hardened/selinux"
    INIT_SYSTEM="${GENTOO_INIT#hardened-selinux-}"
    SUB_PATH="$GENTOO_INIT"
elif [[ "$GENTOO_INIT" == hardened-* ]]; then
    LIBC="glibc"
    FLAVOR="hardened"
    INIT_SYSTEM="${GENTOO_INIT#hardened-}"
    SUB_PATH="$GENTOO_INIT"
else
    LIBC="glibc"
    FLAVOR="desktop"
    INIT_SYSTEM="$GENTOO_INIT"
    SUB_PATH="desktop-$GENTOO_INIT"
fi

# Dynamically fetch GENTOO_STAGE3_URL if set to "-"
if [[ "$GENTOO_STAGE3_URL" == "-" ]]; then
	echo ">>> Dynamically fetching latest Gentoo Stage3 URL..."
	STAGE3_BASE_URL="${GENTOO_MIRROR}releases/$GENTOO_ARCH/autobuilds/"
	STAGE3_FILENAME=$(curl -s "${GENTOO_MIRROR}releases/$GENTOO_ARCH/autobuilds/latest-stage3-$GENTOO_ARCH-$SUB_PATH.txt" |
		grep -v '^#' | grep '\.tar\.xz' | awk '{print $1}' | head -n1)
	if [[ -z "$STAGE3_FILENAME" ]]; then
		echo "Error: Could not dynamically fetch Stage3 filename. Exiting."
		exit 1
	fi
	GENTOO_STAGE3_URL="${STAGE3_BASE_URL}${STAGE3_FILENAME}"
	echo ">>> Fetched Stage3 URL: $GENTOO_STAGE3_URL"
fi

if [[ "$2" != "" ]]; then
	OUTPUT_SFS="$2"
	echo ">>> Custom sfs output: $2"
fi

# Check for needed commands
check_command mksquashfs "mksquashfs is provided by squashfs-tools on Gentoo."
check_command wget "wget is needed to download the stage3 tarball."
check_command tar "tar is needed to extract the stage3 tarball."

# Clean up build directories to start creating the filesystem
echo ">>> Cleaning up any previous build directories..."
rm -rf "$BUILD_DIR"
rm -f "$OUTPUT_SFS"
mkdir -p "$BUILD_DIR"

# Bootstrapping system
echo ">>> Downloading Gentoo stage3 tarball..."
STAGE3_TARBALL=$(basename "$GENTOO_STAGE3_URL")
wget -O "/tmp/$STAGE3_TARBALL" "$GENTOO_STAGE3_URL"
echo ">>> Extracting stage3 tarball to $BUILD_DIR..."
tar xpf "/tmp/$STAGE3_TARBALL" --xattrs-include='*.*' --numeric-owner -C "$BUILD_DIR"
echo ">>> Setting up chroot environment..."
mkdir -p "$BUILD_DIR/proc" "$BUILD_DIR/sys" "$BUILD_DIR/dev" "$BUILD_DIR/tmp"
mount -t proc /proc "$BUILD_DIR/proc"
mount --rbind /sys "$BUILD_DIR/sys"
mount --make-rslave "$BUILD_DIR/sys"
mount --rbind /dev "$BUILD_DIR/dev"
mount --make-rslave "$BUILD_DIR/dev"
mount -t tmpfs tmpfs "$BUILD_DIR/tmp"
mkdir -p "$BUILD_DIR/var/tmp"
cp /etc/resolv.conf "$BUILD_DIR/etc/"

# Chroot into the new system
chroot_exec() {
	chroot "$BUILD_DIR" /bin/bash -c "source /etc/profile && export PS1='(chroot) ${PS1}' && export TERM=xterm && $*"
}

echo ">>> Updating Portage tree..."
chroot_exec "emerge --sync"

# systemd uses the /systemd suffixed profile. OpenRC is the default - the plain desktop profile has no suffix.
if [[ "$INIT_SYSTEM" == "systemd" ]]; then
	GENTOO_PROFILE="default/linux/$GENTOO_ARCH/23.0/$FLAVOR/systemd"
else
	GENTOO_PROFILE="default/linux/$GENTOO_ARCH/23.0/$FLAVOR"
fi

echo ">>> Selecting Gentoo profile: $GENTOO_PROFILE"
chroot_exec "eselect profile set $GENTOO_PROFILE"

# Append musl-locales to PACKAGES only if the libc is musl
if [[ "$LIBC" == "musl" ]]; then
    echo ">>> Musl detected: Adding musl specific-packages list..."
    PACKAGES="$PACKAGES sys-apps/musl-locales"
fi

if [[ "$ENABLE_AMDGPU" == "true" ]]; then
	chroot_exec "echo '*/* VIDEO_CARDS: amdgpu radeonsi' >> /etc/portage/package.use/00video_cards"
fi

if [[ "$ENABLE_NVIDIA" == "true" ]]; then
	if [[ "$LIBC" == "musl" ]]; then
		chroot_exec "echo '*/* VIDEO_CARDS: nouveau' >> /etc/portage/package.use/00video_cards"
	fi
	chroot_exec "echo '*/* VIDEO_CARDS: nvidia' >> /etc/portage/package.use/00video_cards"
fi

chroot_exec "echo 'MAKEOPTS=\"-j2\"' >> /etc/portage/make.conf"
chroot_exec "echo 'FEATURES=\"\${FEATURES} parallel-fetch\"' >> /etc/portage/make.conf"
chroot_exec "echo 'EMERGE_DEFAULT_OPTS=\"--jobs=1 --load-average=1.5 --quiet-build=y\"' >> /etc/portage/make.conf"
chroot_exec "echo 'FEATURES=\"${FEATURES} getbinpkg\"' >> /etc/portage/make.conf"
chroot_exec "echo 'FEATURES=\"${FEATURES} binpkg-request-signature\"' >> /etc/portage/make.conf"
chroot_exec "echo 'LICENSE_ACCEPT=\"~$ACCEPT_LICENSE\"' >> /etc/portage/make.conf"
chroot_exec "echo 'ACCEPT_LICENSE=\"~$ACCEPT_LICENSE\"' >> /etc/portage/make.conf"
chroot_exec "echo 'GRUB_PLATFORMS=\"efi-64\"' >> /etc/portage/make.conf"
chroot_exec "echo \"sys-kernel/linux-firmware @BINARY-REDISTRIBUTABLE\" | tee -a /etc/portage/package.license"

if [[ "$INIT_SYSTEM" == "systemd" ]]; then
	chroot_exec "echo \"sys-kernel/installkernel dracut grub\" | tee -a /etc/portage/package.use/installkernel"
	chroot_exec "echo 'USE=\"\${USE} systemd\"' >> /etc/portage/make.conf"
else
	chroot_exec "echo \"sys-kernel/installkernel dracut grub -systemd\" | tee -a /etc/portage/package.use/installkernel"
	chroot_exec "echo 'USE=\"\${USE} -systemd\"' >> /etc/portage/make.conf"
fi

# Suppress ModemManager/WWAN plugin in NetworkManager via config.
# This avoids recompiling NM and works regardless of USE flags.
if [[ "$LIBC" == "musl" ]] || [[ "$FLAVOR" == "hardened" ]] || [[ "$FLAVOR" == "hardened/selinux" ]]; then	
    mkdir -p "$BUILD_DIR/etc/NetworkManager/conf.d"
    cat > "$BUILD_DIR/etc/NetworkManager/conf.d/00-no-modemmanager.conf" << 'NMEOF'
[main]
plugins=keyfile

[device]
wifi.backend=wpa_supplicant
NMEOF
    chroot_exec "echo 'net-wireless/wpa_supplicant dbus' >> /etc/portage/package.use/wpa_supplicant"
fi

chroot_exec "echo \"sys-fs/squashfs-tools zstd xz\" | tee -a /etc/portage/package.use/squashfs"
chroot_exec "echo 'ACCEPT_KEYWORDS=\"~$GENTOO_ARCH\"' >> /etc/portage/make.conf"

# Install a portage bashrc hook that re-applies the chroot bypass AFTER each package postinst.
echo ">>> Installing portage bashrc hook to bypass dracut chroot check..."
mkdir -p "$BUILD_DIR/etc/portage"
cat > "$BUILD_DIR/etc/portage/bashrc" << 'EOF'
post_pkg_postinst() {
    case "${CATEGORY}/${PN}" in
        sys-kernel/installkernel|sys-kernel/gentoo-kernel-bin)
            mkdir -p /etc/kernel/install.d/ /etc/kernel/preinst.d/ /usr/lib/kernel/preinst.d/
            touch /etc/kernel/install.d/05-check-chroot.install
            touch /etc/kernel/preinst.d/05-check-chroot.install
            touch /usr/lib/kernel/preinst.d/05-check-chroot.install
            ;;
    esac
}
EOF

echo ">>> Pre-creating kernel-install chroot bypass..."
mkdir -p "$BUILD_DIR/etc/kernel/install.d" "$BUILD_DIR/etc/kernel/preinst.d" "$BUILD_DIR/usr/lib/kernel/preinst.d"
touch "$BUILD_DIR/etc/kernel/install.d/05-check-chroot.install"
touch "$BUILD_DIR/etc/kernel/preinst.d/05-check-chroot.install"
touch "$BUILD_DIR/usr/lib/kernel/preinst.d/05-check-chroot.install"
echo 'KERNEL_INSTALL_BYPASS_CHECKS=1' >> "$BUILD_DIR/etc/environment"

echo ">>> Installing specified packages..."
if [[ "$GENTOO_PREFER_BINHOST" == "true" ]]; then
	EMERGE_OPTS="-g --binpkg-respect-use=y --binpkg-changed-deps=y -k"
else
	EMERGE_OPTS=""
fi

# Staged emerge with cleanup between stages
cleanup_chroot() {
	echo ">>> Cleaning chroot scratch space..."
	chroot_exec '
		rm -rf /var/tmp/portage/* 2>/dev/null
		rm -rf /var/cache/binpkgs/* 2>/dev/null
		rm -rf /var/cache/distfiles/* 2>/dev/null
		rm -f /var/log/emerge*.log 2>/dev/null
		rm -rf /var/log/portage/* 2>/dev/null
		true
	'
	#echo ">>> /tmp usage after cleanup:"
	#df -h /tmp 2>/dev/null | tail -1 || true
}

emerge_stage() {
   local stage_name="$1"
   shift
   local pkgs="$*"
    
   if ! chroot_exec "emerge --noreplace $EMERGE_OPTS $pkgs"; then
     echo "" >&2
     echo ">>> FATAL: emerge failed at stage '$stage_name'." >&2
     exit 1
   fi
   cleanup_chroot
}

emerge_stage "base-userspace" \
	sys-apps/baselayout app-arch/xz-utils app-admin/sudo \
	dev-lang/python net-misc/networkmanager

emerge_stage "tools" \
	app-editors/nano

emerge_stage "bootloader-prereqs" \
	sys-boot/efibootmgr sys-boot/grub sys-kernel/dracut \
	sys-kernel/installkernel

emerge_stage "firmware" \
	sys-kernel/linux-firmware

emerge_stage "kernel" \
	sys-kernel/gentoo-kernel-bin

emerge_stage "extras" $PACKAGES

# Check if kernels are present otherwise copy it.
chroot_exec '
    kver=$(ls /lib/modules/ 2>/dev/null | head -n1)
    if [ -z "$kver" ]; then
        echo ">>> FATAL: no kernel modules found in /lib/modules/" >&2
        echo ">>> gentoo-kernel-bin did not install correctly." >&2
        exit 1
    fi
    if [ ! -f "/boot/vmlinuz-$kver" ]; then
        echo ">>> /boot/vmlinuz-$kver missing; copying from /usr/lib/modules/$kver/vmlinuz"
        if [ -f "/usr/lib/modules/$kver/vmlinuz" ]; then
            cp "/usr/lib/modules/$kver/vmlinuz" "/boot/vmlinuz-$kver"
        else
            echo ">>> FATAL: no vmlinuz at /usr/lib/modules/$kver/vmlinuz either" >&2
            exit 1
        fi
    fi
    echo ">>> Confirmed kernel image at /boot/vmlinuz-$kver"
'

echo ">>> Rebuilding dracut initramfs with dmsquash-live + cdrom/isofs drivers..."
chroot_exec "mkdir -p /etc/dracut.conf.d && printf 'add_dracutmodules+=\" dmsquash-live \"\nadd_drivers+=\" cdrom isofs squashfs loop overlay \"\nhostonly=no\n' > /etc/dracut.conf.d/livecd.conf"

if [[ "$INIT_SYSTEM" == "systemd" ]]; then
	if ! chroot_exec "kver=\$(ls /lib/modules/ | head -n1) && dracut -a \"systemd\"  --force --kver \"\$kver\" /boot/initramfs-\${kver}.img && echo \">>> dracut done for kernel \$kver\""; then
		echo ">>> FATAL: dracut failed to build initramfs (systemd path)." >&2
		exit 1
	fi
else
	if ! chroot_exec "kver=\$(ls /lib/modules/ | head -n1) && dracut --force --omit \"systemd\" --kver \"\$kver\" /boot/initramfs-\${kver}.img && echo \">>> dracut done for kernel \$kver\""; then
		echo ">>> FATAL: dracut failed to build initramfs (openrc path)." >&2
		exit 1
	fi
fi

# Verify both kernel and initramfs are present.
chroot_exec '
    kver=$(ls /lib/modules/ | head -n1)
    missing=0
    [ -f "/boot/vmlinuz-$kver" ] || { echo ">>> FATAL: /boot/vmlinuz-$kver missing" >&2; missing=1; }
    [ -f "/boot/initramfs-$kver.img" ] || { echo ">>> FATAL: /boot/initramfs-$kver.img missing" >&2; missing=1; }
    [ "$missing" -eq 0 ] || exit 1
    echo ">>> Verified /boot/ contains kernel and initramfs for $kver"
'

if [[ "$ENABLE_NVIDIA" == "true" ]]; then
	if [[ "$LIBC" == "musl" ]]; then
		echo ">>> Configuring NVIDIA drivers in dracut.conf... (musl)"
		cat >> "$BUILD_DIR/etc/dracut.conf" << 'EOF'
# add_drivers+=" i915 " # Note leading and trailing spaces
add_drivers+=" nouveau " # Note leading and trailing spaces
# force_drivers+=" i915 " # Note leading and trailing spaces
force_drivers+=" nouveau " # Note leading and trailing spaces
EOF
	fi
fi

# Enabling services and copying scripts
echo ">>> Enabling services to start on boot..."
if [[ "$INIT_SYSTEM" == "systemd" ]]; then
	chroot_exec "systemctl enable $SERVICES"
elif [[ "$INIT_SYSTEM" == "openrc" ]]; then
	# Enable standard user services
	for s in $SERVICES; do chroot_exec "rc-update add \"$s\" default"; done

	# musl stage3 ships with sysvinit as PID 1. We switch to openrc-init
	echo ">>> Switching init from sysvinit to openrc-init..."	
	chroot_exec "emerge --noreplace sys-apps/openrc" || true
	chroot_exec "emerge --deselect sys-apps/sysvinit 2>/dev/null || true"
	chroot_exec "emerge -C sys-apps/sysvinit 2>/dev/null || true"
	chroot_exec "rm -f /etc/inittab"
	
	chroot_exec "ln -sf /sbin/openrc-init /sbin/init"

	for n in $(seq 1 6); do
		chroot_exec "ln -sf agetty /etc/init.d/agetty.tty$n"
		chroot_exec "rc-update add agetty.tty$n default"
	done
fi

# Create admin user
if [[ -n "$ADMIN_USER" ]]; then
	echo "Creating user $ADMIN_USER..."
	chroot_exec "useradd -m -G wheel,video,audio,input -s /bin/bash \"$ADMIN_USER\""

	if [[ -n "$ADMIN_DOTFILES_TYPE" ]]; then
		if [[ "$ADMIN_DOTFILES_TYPE" == "HOME" ]]; then
			chroot_exec "su - \"$ADMIN_USER\" -c \"git clone \"$ADMIN_DOTFILES\" ~/dotfiles && cp -r ~/dotfiles/.??* ~/ && rm -rf ~/.git\""
		elif [[ "$ADMIN_DOTFILES_TYPE" == "CONFIG" ]]; then
			chroot_exec "su - \"$ADMIN_USER\" -c \"git clone \"$ADMIN_DOTFILES\" ~/.config\""
		else
			cp -r /home/"$ADMIN_DOTFILES_TYPE"/.??* "$BUILD_DIR/home/$ADMIN_USER/"
		fi
		if [[ -n "$POST_INSTALL" ]]; then
			chroot_exec "su - \"$ADMIN_USER\" -c \"$POST_INSTALL\""
		fi
	fi
	chroot_exec "echo '%wheel ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers"

	# Add user password interactively
	echo ">>> Please set the password for $ADMIN_USER"
	if [[ -n "$ADMIN_PASSWORD" ]]; then
		chroot_exec "bash -c \"echo '${ADMIN_USER}:${ADMIN_PASSWORD}' | chpasswd\""
		echo ">>> Password defined in config. skipping..."
	else
		chroot_exec "passwd "$ADMIN_USER""
	fi
fi

if [[ -n "$CUSTOM_SCRIPTS_DIR" ]]; then
	echo ">>> Copying custom scripts to chroot..."
	SCRIPT_TEMP_DIR="/root/custom_scripts"
	mkdir -p "$BUILD_DIR/$SCRIPT_TEMP_DIR"
	cp -r "$CUSTOM_SCRIPTS_DIR/*" "$BUILD_DIR/$SCRIPT_TEMP_DIR/"
	echo ">>> Making custom scripts executable and running main.sh..."
	chroot_exec "chmod +x $SCRIPT_TEMP_DIR/* && $SCRIPT_TEMP_DIR/main.sh"
	echo ">>> Cleaning up custom scripts from chroot..."
	rm -rf "$BUILD_DIR/$SCRIPT_TEMP_DIR"
fi

if [[ -n "$TIMEZONE" ]]; then
	echo "Setting timezone to $TIMEZONE..."
	chroot_exec "echo "$TIMEZONE" > /etc/timezone"

	if [[ "$LIBC" == "musl" ]]; then
        echo ">>> Emerging timezone-data for musl..."
        chroot_exec "emerge sys-libs/timezone-data"
        
        echo ">>> Setting TZ environment variable for musl..."
        chroot_exec "mkdir -p /etc/profile.d"
        chroot_exec "echo 'export TZ=\"$TIMEZONE\"' > /etc/profile.d/timezone.sh"
        chroot_exec "ln -sf /usr/share/zoneinfo/$TIMEZONE /etc/localtime"
    else
        chroot_exec "emerge --config sys-libs/timezone-data"
    fi
fi

# Generate machine-id so bash profile doesn't error on boot
if [[ "$INIT_SYSTEM" == "systemd" ]]; then
	chroot_exec "systemd-machine-id-setup 2>/dev/null || dbus-uuidgen > /etc/machine-id"
else
	chroot_exec "dbus-uuidgen > /etc/machine-id 2>/dev/null || true"
fi

# Set locale
echo ">>> Setting locale to en_US.UTF-8..."
if [[ "$LIBC" == "musl" ]]; then
		mkdir -p "$BUILD_DIR/etc/env.d"
		chroot_exec "echo \"MUSL_LOCPATH=/usr/share/i18n/locales/musl\" > /etc/env.d/00local"
    chroot_exec "env-update"
else
    chroot_exec "echo 'en_US.UTF-8 UTF-8' > /etc/locale.gen"
    chroot_exec "locale-gen"
    chroot_exec "eselect locale set en_US.utf8"
fi

if [[ -n "$HOSTNAME" ]]; then
	echo "Setting hostname to $HOSTNAME..."
	echo "$HOSTNAME" >"$BUILD_DIR/etc/hostname"
	if [[ "$INIT_SYSTEM" == "openrc" ]]; then
		# OpenRC reads hostname from /etc/openrc/conf.d/hostname
		mkdir -p "$BUILD_DIR/etc/openrc/conf.d"
		echo "hostname=\"$HOSTNAME\"" >"$BUILD_DIR/etc/openrc/conf.d/hostname"
		echo "hostname=\"$HOSTNAME\"" >"$BUILD_DIR/etc/conf.d/hostname"
	else
		# systemd reads hostname from /etc/hostname
		mkdir -p "$BUILD_DIR/etc/conf.d"
		echo "hostname=\"$HOSTNAME\"" >"$BUILD_DIR/etc/conf.d/hostname"
	fi
fi

# OpenRC does not auto-mount /tmp as tmpfs unlike systemd (which uses tmp.mount).
if [[ "$INIT_SYSTEM" == "openrc" ]]; then
	echo ">>> Adding /tmp tmpfs entry to /etc/fstab for OpenRC..."
	echo "tmpfs /tmp tmpfs rw,nosuid,nodev,size=4G,mode=1777 0 0" >> "$BUILD_DIR/etc/fstab"
	echo ">>> Creating /run/etc_ab mount point for OpenRC..."
	mkdir -p "$BUILD_DIR/run/etc_ab"
fi

# Add root password
if [[ -z "$ROOT_HAVEPASSWORD" ]]; then
	echo ">>> Please set the password for the root user"
	chroot_exec "passwd root"
else
	chroot_exec "passwd -d root"
fi

# branding (configure.sh rejects root, so run it as a temporary user)
chroot_exec "useradd -m -s /bin/bash _obsidian_branding 2>/dev/null || true"
chroot_exec "echo '_obsidian_branding ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers"
chroot_exec "echo 'Defaults:_obsidian_branding !lecture' >> /etc/sudoers"
chroot_exec "su - _obsidian_branding -c 'curl -fsSL https://obsidianos.xyz/configure.sh | bash'"
chroot_exec "sed -i '/_obsidian_branding/d' /etc/sudoers"
chroot_exec "userdel -r _obsidian_branding 2>/dev/null || true"

# These provide obsidianctl (installer), plugind, obsidianwall, and branding
echo ">>> Installing ObsidianOS packages from source..."
cat > "$BUILD_DIR/tmp/_obsidian_install.sh" << 'INSTALL_EOF'
#!/bin/bash

clone_or_warn() {
    local pkg="$1"
    local dest="/opt/${pkg}"
    rm -rf "$dest"
 
    git clone "https://github.com/Obsidian-OS/${pkg}.git" "$dest" 2>/dev/null || {
        echo ">>> WARN: Could not clone ${pkg}, skipping"
        return 1
    }
    return 0
}

# obsidianctl - needs `make build` first to concatenate modules, then `make install`
echo ">>> Installing obsidianctl..."
if clone_or_warn obsidianctl; then
    cd /opt/obsidianctl && make build && make install || echo ">>> WARN: obsidianctl build/install failed"
    echo ">>> obsidianctl installed at /usr/local/sbin/obsidianctl"
fi

# obsidianwall - install if present
echo ">>> Installing obsidianwall..."
if clone_or_warn obsidianwall; then
    if [ -f /opt/obsidianwall/Makefile ]; then
        cd /opt/obsidianwall && make build 2>/dev/null; make install || true
    elif [ -f /opt/obsidianwall/install.sh ]; then
        bash /opt/obsidianwall/install.sh
    elif [ -f /opt/obsidianwall/obsidianwall ]; then
        chmod +x /opt/obsidianwall/obsidianwall
        ln -sf /opt/obsidianwall/obsidianwall /usr/local/bin/obsidianwall
    fi
fi

# plugind - install if present
echo ">>> Installing plugind..."
if clone_or_warn plugind; then
    if [ -f /opt/plugind/Makefile ]; then
        cd /opt/plugind && make build 2>/dev/null; make install || true
    elif [ -f /opt/plugind/install.sh ]; then
        bash /opt/plugind/install.sh
    elif [ -f /opt/plugind/plugind ]; then
        chmod +x /opt/plugind/plugind
        ln -sf /opt/plugind/plugind /usr/local/bin/plugind
    fi
    if [ -f /opt/plugind/plugind.service ]; then
        if command -v systemctl &>/dev/null; then
            mkdir -p /etc/systemd/system/
            cp /opt/plugind/plugind.service /etc/systemd/system/
        else
            # OpenRC: generate a proper init script from the service file
            EXEC=$(grep -i "^ExecStart=" /opt/plugind/plugind.service | cut -d= -f2-)
            mkdir -p /etc/init.d/
         
            cat > /etc/init.d/plugind << INITEOF
#!/sbin/openrc-run
description="plugind service"
command="$EXEC"
command_background=true
pidfile="/run/plugind.pid"
depend() {
    need net
}
INITEOF
            chmod +x /etc/init.d/plugind
        fi
    fi
fi

echo ">>> ObsidianOS tooling installation complete."
INSTALL_EOF
chmod +x "$BUILD_DIR/tmp/_obsidian_install.sh"
chroot_exec "bash /tmp/_obsidian_install.sh" || echo ">>> WARN: ObsidianOS package install had errors, continuing"
rm -f "$BUILD_DIR/tmp/_obsidian_install.sh"

# Enable plugind service if it was installed
if [[ "$INIT_SYSTEM" == "systemd" ]]; then
	chroot_exec "systemctl enable plugind 2>/dev/null || true"
else
	chroot_exec "rc-update add plugind default 2>/dev/null || true"
fi

# Create a systemd service to symlink the live squashfs to /etc/system.sfs
# so obsidianctl can find it at its expected path on every live boot.
if [[ "$INIT_SYSTEM" == "systemd" ]]; then
mkdir -p "$BUILD_DIR/etc/systemd/system"
cat > "$BUILD_DIR/etc/systemd/system/obsidian-livesfs.service" << 'EOF'
[Unit]
Description=Symlink live squashfs to /etc/system.sfs for obsidianctl
After=local-fs.target
ConditionPathExists=/run/initramfs/live/LiveOS/squashfs.img

[Service]
Type=oneshot
ExecStart=/bin/ln -sf /run/initramfs/live/LiveOS/squashfs.img /etc/system.sfs
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
chroot_exec "systemctl enable obsidian-livesfs"
else
	# OpenRC: use a local.d startup script instead
	mkdir -p "$BUILD_DIR/etc/local.d"
	cat > "$BUILD_DIR/etc/local.d/obsidian-livesfs.start" << 'ORCEOF'
#!/bin/bash
[ -f /run/initramfs/live/LiveOS/squashfs.img ] && ln -sf /run/initramfs/live/LiveOS/squashfs.img /etc/system.sfs
ORCEOF
	chmod +x "$BUILD_DIR/etc/local.d/obsidian-livesfs.start"
fi

# Copy config to target system
echo ">>> Copying a backup of the system image configuration to /etc/config.mkgentoosfs"
cp "$1" "$BUILD_DIR/etc/config.mkgentoosfs" || true

# Cleanup chroot mounts
echo ">>> Aggressively cleaning up Portage caches to free up RAM..."
cleanup_chroot
echo ">>> Removing downloaded stage3 tarball to free up space..."
rm -f "/tmp/$STAGE3_TARBALL"

echo ">>> Cleaning up chroot mounts..."
umount -R "$BUILD_DIR/dev" 2>/dev/null || true
umount -R "$BUILD_DIR/sys" 2>/dev/null || true
umount -R "$BUILD_DIR/proc" 2>/dev/null || true
umount -R "$BUILD_DIR/var/tmp" 2>/dev/null || true
umount -R "$BUILD_DIR/tmp" 2>/dev/null || true

# Creating SquashFS image
echo ">>> Creating the SquashFS image ($OUTPUT_SFS)..."
cores=$(nproc)
available_mem=$(awk '/MemAvailable/ {print int(($2-1048576)/1024)}' /proc/meminfo)
usable_mem=$(( available_mem > 1024 ? available_mem - 512 : available_mem ))
mem=$(( usable_mem / (cores >= 2 ? cores : 1) ))
echo "Available Memory: ${available_mem}"
echo "Memory: ${mem}"
echo "Cores: ${cores}"

fallback_cores=$(( cores < 2 ? cores : 2 ))
fallback_mem=512

if ! mksquashfs "$BUILD_DIR" "$OUTPUT_SFS" -noappend -comp xz -processors "$cores" -mem "${mem}M"; then
	echo ">>> WARN: mksquashfs failed with -processors $cores -mem ${mem}M." >&2
	echo ">>> Retrying with conservative fallback: -processors $fallback_cores -mem ${fallback_mem}M..." >&2
	rm -f "$OUTPUT_SFS"
	if ! mksquashfs "$BUILD_DIR" "$OUTPUT_SFS" -noappend -comp xz -processors "$fallback_cores" -mem "${fallback_mem}M"; then
		echo "Error: mksquashfs failed to create the image (both primary and fallback attempts)." >&2
		exit 1
	fi
	echo ">>> mksquashfs succeeded with fallback settings."
fi
echo ">>> Cleaning up the build directory..."
rm -rf "$BUILD_DIR"
echo "---"
echo ">>> Success! ObsidianOS Gentoo system image created at: $(pwd)/$OUTPUT_SFS"
echo ">>> Packages included: $PACKAGES"
